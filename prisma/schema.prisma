// ═══════════════════════════════════════════════════════════════════
// CFO Pilot — Metadata Engine v2 (DRAFT)
// Locked decisions: 5 always-on dims + ICP toggleable + 8 UDs
// Status: PROPOSAL — review before replacing schema.prisma
// Author: epm-architect + engineer  |  Date: 2026-05-21
// ═══════════════════════════════════════════════════════════════════

// NOTE: This is a DRAFT. It shows the SHAPE of the updated metadata model.
// Per-dimension property deep-dive happens next. Treat this as the
// skeleton everyone agrees on, not the final field list.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enumerations (the typed, no-string-magic kind) ───────────────

enum UserRole {
  ADMIN
  FINANCE_MANAGER
  FINANCE_USER
  VIEWER
}

// FIX: added STATISTICAL, KPI, NON_FINANCIAL per blueprint §4
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  STATISTICAL
  KPI
  NON_FINANCIAL
}

// NEW: typed enums for what used to be string fields
enum TimeBalance {
  FLOW      // P&L-style: sum across periods
  LAST      // Balance sheet: take period-end value
  FIRST     // Period-open value
  AVG       // Average across period
}

enum AggregationOperator {
  ADD       // "+"
  SUBTRACT  // "-"
  IGNORE    // "~"
}

enum StorageType {
  STORED        // input or imported, lives in fact table
  DYNAMIC       // calculated on read
  NEVER_SHARE   // calculated but not allowed as shared member
}

enum CalculationType {
  INPUT
  FORMULA
  ROLLUP
}

enum VarianceType {
  EXPENSE       // Actual > Budget = unfavourable
  NON_EXPENSE   // Actual > Budget = favourable
  NEUTRAL
}

enum CurrencyBehavior {
  TRANSACTIONAL  // translate using account's rate type
  TRANSLATED     // already in reporting currency
  NONE           // statistical/non-financial, no translation
}

enum ConsolidationMethod {
  FULL
  PROPORTIONAL
  EQUITY
  NONE
}

enum ScenarioType {
  ACTUAL
  BUDGET
  FORECAST
  WHATIF
}

enum TimePeriodType {
  MONTH
  QUARTER
  HALF
  YEAR
}

enum DimensionKind {
  // Always-on (5)
  ACCOUNT
  ENTITY
  SCENARIO
  TIME
  CURRENCY
  // Toggleable (1) — system-managed, derived from Entity.icp_enabled
  ICP
  // Always-on data-source dim (OneStream-style "Origin"). Seeded with
  // 'Import'; admins can add Form / AI / Calc / Elim / Consol / Translation
  // later. Every fact row carries originId so we can filter by source.
  ORIGIN
  // Customer-defined slots (8)
  UD1
  UD2
  UD3
  UD4
  UD5
  UD6
  UD7
  UD8
}

// ─── Core Tenant + Users ─────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Global POV defaults — propagate as initial state to every page ───
  // (Per OneStream convention: tenant has a "current POV" that becomes the
  //  default everywhere; users can still override per-page.)
  defaultPeriodCode         String?    // e.g. "FY2026" / "2026Q3" / "2026M04"
  defaultScenarioCode       String?    // e.g. "Actual"
  defaultCompareScenarioCode String?    // e.g. "Budget" — for variance views
  defaultEntityCode         String?    // e.g. "APOLLO_GRP" (consolidated)

  users           User[]
  features        TenantFeature[]
  dimensions      Dimension[]
  members         DimensionMember[]
  hierarchies     Hierarchy[]
  hierarchyEdges  HierarchyEdge[]
  currencies      CurrencyRef[]     // per-tenant active list, seeded from CurrencyCatalog
  auditLogs       AuditLog[]
  factRows        FactRow[]
  dataForms       DataForm[]
  fxRates         FxRate[]
  processRuns     ProcessRun[]
  loadBatches     LoadBatch[]
  aiCacheEntries  AiCache[]
  aiCallLogs      AiCallLog[]
  closeRuns       CloseRun[]
  closeTasks      CloseTask[]
  calcRules       CalcRule[]
  calcRuleRuns    CalcRuleRun[]
  automationJobs  AutomationJob[]
  jobRuns         JobRun[]
  copilotConvos   CopilotConversation[]
  snapshots       Snapshot[]

  @@index([slug])
  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  name         String
  passwordHash String
  role         UserRole  @default(FINANCE_USER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ─── Feature flags (drives which dims/modules are enabled) ────────

model TenantFeature {
  id          String   @id @default(uuid())
  tenantId    String
  featureKey  String   // e.g. multi_entity_enabled, intercompany_enabled
  isEnabled   Boolean  @default(false)
  enabledAt   DateTime?
  enabledBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@index([tenantId])
  @@map("tenant_features")
}

// Known feature keys (validated in app layer):
//   multi_entity_enabled           (default false)
//   multi_currency_enabled         (default false)
//   intercompany_enabled           (default false)  -> turns on ICP dim
//   alternate_hierarchy_enabled    (default true)
//   department_enabled             (default true)   -> reserves a UD slot
//   cost_center_enabled            (default false)
//   project_enabled                (default false)

// ─── Dimension Definitions ────────────────────────────────────────

model Dimension {
  id           String        @id @default(uuid())
  tenantId     String
  kind         DimensionKind                  // ACCOUNT, ENTITY, ... UD1..UD8
  code         String                          // 'account', 'entity', or for UDs e.g. 'doctor'
  label        String                          // display name e.g. "Doctor"
  description  String?
  isEnabled    Boolean       @default(true)    // toggled off via tenant feature flags
  isCustom     Boolean       @default(false)   // true for UD1..UD8 when user names them
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members     DimensionMember[]
  hierarchies Hierarchy[]

  @@unique([tenantId, kind])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("dimensions")
}

// ─── Dimension Members (the actual rows like accounts, entities) ──
// One generic table holds every member, regardless of dimension.
// Dimension-specific properties go into typed JSON `properties` until
// we promote heavily-used fields into columns in v2.1.

model DimensionMember {
  id          String   @id @default(uuid())
  tenantId    String
  dimensionId String
  memberCode  String                          // e.g. account_code, entity_code
  memberName  String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  // Typed common fields used across dims (filled when relevant)
  storageType     StorageType?
  calculationType CalculationType?
  formula         String?
  // Dimension-specific properties bag — narrowed by Zod in app
  // For Account: accountType, timeBalance, switchSign, varianceType, currencyBehavior, allowInput
  // For Entity:  baseCurrency, consolidationMethod, ownershipPct, icpEnabled, country
  // For Scenario: scenarioType, isFrozen, version, startPeriod, endPeriod
  // For Time:    periodType, fiscalYear, parentCode
  // For Currency: ref to CurrencyCatalog (iso_code)
  // For ICP:     entityId (link back to Entity member)
  // For UD1..8:  free-form per tenant
  properties  Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dimension Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  parentEdges HierarchyEdge[] @relation("ChildEdges")
  childEdges  HierarchyEdge[] @relation("ParentEdges")

  @@unique([tenantId, dimensionId, memberCode])
  @@index([tenantId, dimensionId])
  @@index([tenantId, isActive])
  @@map("dimension_members")
}

// ─── Hierarchies (SEPARATE table — supports alternate hierarchies,
//      shared members, cycle detection, effective dating)

model Hierarchy {
  id              String   @id @default(uuid())
  tenantId        String
  dimensionId     String
  code            String                          // 'default', 'statutory', 'management'
  name            String
  description     String?
  isPrimary       Boolean  @default(false)        // exactly one per dimension
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dimension Dimension       @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  edges     HierarchyEdge[]

  @@unique([tenantId, dimensionId, code])
  @@index([tenantId, dimensionId])
  @@map("hierarchies")
}

model HierarchyEdge {
  id            String              @id @default(uuid())
  tenantId      String
  hierarchyId   String
  parentMemberId String
  childMemberId  String
  operator      AggregationOperator @default(ADD)
  weight        Decimal             @default(1) @db.Decimal(10, 6)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hierarchy Hierarchy        @relation(fields: [hierarchyId], references: [id], onDelete: Cascade)
  parent    DimensionMember  @relation("ParentEdges", fields: [parentMemberId], references: [id], onDelete: Cascade)
  child     DimensionMember  @relation("ChildEdges",  fields: [childMemberId],  references: [id], onDelete: Cascade)

  // Cycle detection enforced in app layer (recursive CTE check on insert).
  // Shared members supported by allowing the same child under multiple parents
  // within the same hierarchy (uniqueness is on the edge, not the child).

  @@unique([tenantId, hierarchyId, parentMemberId, childMemberId])
  @@index([tenantId, hierarchyId])
  @@index([tenantId, parentMemberId])
  @@index([tenantId, childMemberId])
  @@map("hierarchy_edges")
}

// ─── Currency Catalog (seeded with ISO 4217) ──────────────────────

model CurrencyCatalog {
  isoCode    String  @id          // "USD", "EUR", "INR", ...
  name       String                // "US Dollar"
  symbol     String                // "$"
  decimals   Int     @default(2)
  isActive   Boolean @default(true)
  // 180+ rows seeded via prisma/seed.ts on first migrate

  @@map("currency_catalog")
}

// Per-tenant active currency list (which currencies this tenant uses)
model CurrencyRef {
  id        String   @id @default(uuid())
  tenantId  String
  isoCode   String   // FK to CurrencyCatalog
  isBase    Boolean  @default(false)   // exactly one base per tenant
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, isoCode])
  @@index([tenantId])
  @@map("currency_refs")
}

// ─── Audit Log (every metadata change) ────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  IMPORT
  EXPORT
  BULK_UPDATE
  ENABLE_FEATURE
  DISABLE_FEATURE
  APPROVE
  REJECT
  LOGIN
  LOGOUT
}

model AuditLog {
  id         String      @id @default(uuid())
  tenantId   String
  userId     String?
  action     AuditAction
  entityType String @default("legacy")   // 'dimension_member', 'hierarchy_edge', 'tenant_feature' — default lets push backfill old rows
  entityId   String?
  before     Json?
  after      Json?
  metadata   Json?                       // e.g. import_job_id, source_row_id
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

// ─── Fact Rows (the actual data values) ───────────────────────────

// One row per intersection. Every fact carries an originId so we can filter
// by source (Import / Form / AI / Calc / etc.). UD1..UD8 are nullable —
// only the tenant's enabled UDs get values, the rest stay NULL.
//
// All dim FKs reference dimension_members.id directly — no separate fact_dim
// lookup table. That keeps the read path one join shallower.

model FactRow {
  id          BigInt   @id @default(autoincrement())
  tenantId    String
  scenarioId  String
  timeId      String                 // leaf MONTH (or week/day) only — rollups derived
  entityId    String
  accountId   String
  currencyId  String
  icpId       String                 // FK to dimension_member, defaults to [None]
  originId    String                 // FK to dimension_member in ORIGIN dim (Form / Import / AI / ...)
  ud1Id       String?
  ud2Id       String?
  ud3Id       String?
  ud4Id       String?
  ud5Id       String?
  ud6Id       String?
  ud7Id       String?
  ud8Id       String?

  // Three currency views. V1 sets all three equal until multi-currency lands.
  valueTxn       Decimal @db.Decimal(28, 8) @default(0)
  valueLocal     Decimal @db.Decimal(28, 8) @default(0)
  valueReporting Decimal @db.Decimal(28, 8) @default(0)

  // Versioning + audit lineage
  loadBatchId    String?               // null for manual form input
  rateSetId      String?               // FK to FxRateSet when we ship FX
  sourceRowHash  Bytes?                // dedup key for file imports
  version        Int     @default(1)
  isCurrent      Boolean @default(true)
  postedBy       String                // user.id who saved it
  postedAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Unique on full intersection + version flag — only one isCurrent=true row
  // per intersection per origin. Re-saves bump version and supersede.
  @@unique([tenantId, scenarioId, timeId, entityId, accountId, icpId, originId, ud1Id, ud2Id, ud3Id, ud4Id, ud5Id, ud6Id, ud7Id, ud8Id, isCurrent], name: "fact_intersection_current")
  // Query indexes for the common access patterns
  @@index([tenantId, scenarioId, timeId, entityId])           // POV-scoped grid load
  @@index([tenantId, accountId, timeId])                       // account-history queries
  @@index([tenantId, postedAt])                                // recent-activity feed
  @@map("fact_rows")
}

// ─── Data Forms (admin-defined input/review forms) ────────────────

// A form scopes the /data/input grid to a curated subset of accounts +
// time periods + a specific layout. Without forms the page tries to show
// every account on rows, which is unusable past ~30 accounts.
//
// Three layout types in V1:
//   STANDARD       — Account on rows, Time on columns (single scenario in POV)
//   VARIANCE       — Account on rows, Time × Scenario crossjoin on columns,
//                    auto-generated Δ% per period from the two selected scenarios
//   SCENARIO_STACK — Account on rows, Scenario on columns (single Time in POV)
//
// Member selection per axis is captured as JSON for forward-compat with
// richer pickers (parent + descendants, by property filter, etc.).

enum DataFormLayoutType {
  STANDARD
  VARIANCE
  SCENARIO_STACK
}

model DataForm {
  id          String             @id @default(uuid())
  tenantId    String
  code        String                                // url-friendly, e.g. 'pl_input'
  name        String                                // display, e.g. 'P&L Input'
  description String?
  layoutType  DataFormLayoutType @default(STANDARD)

  // Row axis (V1: always Account). selection JSON shape:
  //   { kind: 'all_leaves' } |
  //   { kind: 'children_of', parentMemberId: '<uuid>' } |
  //   { kind: 'manual', memberIds: ['<uuid>', ...] }
  rowDimKind     String  @default("ACCOUNT")
  rowSelection   Json    @default("{\"kind\":\"all_leaves\"}")

  // Column axis 1 (usually Time). Same selection shape.
  colDimKind     String  @default("TIME")
  colSelection   Json    @default("{\"kind\":\"all_leaves\"}")

  // For VARIANCE / SCENARIO_STACK: which scenarios cross-join into cols.
  // Stored as ordered array of scenario member IDs (typically [actual, budget]).
  // For VARIANCE the third synthetic column 'Δ%' is computed as (s0 - s1) / s1.
  scenarioIds    String[]                          // 0 entries for STANDARD

  // POV defaults — JSON map of { dimKind: defaultMemberId }
  povDefaults    Json    @default("{}")

  isActive       Boolean @default(true)
  isDefault      Boolean @default(false)            // exactly 0 or 1 per tenant
  createdBy      String
  createdAt      DateTime @default(now())
  updatedBy      String?
  updatedAt      DateTime @updatedAt

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("data_forms")
}

// ═══════════════════════════════════════════════════════════════════
// FX Rates — manual upload per (fromCcy, toCcy, period). Phase 2 = live
// API. Translation reads rateType per Account.time_balance (FLOW = avg,
// BALANCE = closing). Rate values stored as Decimal for exactness — never
// cast to Float anywhere in the codebase, or you get sub-cent drift on
// large balances.
// ═══════════════════════════════════════════════════════════════════

model FxRate {
  id          String   @id @default(uuid())
  tenantId    String

  // ISO codes — string not member id, so the same rate row is reusable
  // across tenants in future shared-rates feature.
  fromCcy     String                                // e.g. "INR"
  toCcy       String                                // e.g. "USD"
  periodCode  String                                // e.g. "2026M01" — links to Time member code
  rateType    String   @default("CLOSING")          // CLOSING | AVERAGE | OPENING | HISTORICAL
  rate        Decimal  @db.Decimal(28, 12)          // 1 fromCcy = rate * toCcy

  source      String?                               // 'manual' | 'rbi_scrape' | 'ecb_api' — provenance for audit
  uploadedBy  String
  uploadedAt  DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // One rate per (tenant, pair, period, rateType) — re-upload supersedes
  @@unique([tenantId, fromCcy, toCcy, periodCode, rateType], name: "fx_rate_key")
  @@index([tenantId, periodCode])
  @@map("fx_rates")
}

// ═══════════════════════════════════════════════════════════════════
// Process runs — every Consolidation / Translation / Allocation / Import
// run goes here. Powers the run-history view and lets us re-run / diff
// previous runs. Status drives the badge on the launcher screen.
// ═══════════════════════════════════════════════════════════════════

model ProcessRun {
  id          String   @id @default(uuid())
  tenantId    String

  // What kind of process. Strings (not enum) so we can add new process
  // types without a migration. Known values:
  //   'CONSOLIDATION' | 'TRANSLATION' | 'ALLOCATION' | 'CALC' |
  //   'FACTS_IMPORT' | 'METADATA_IMPORT' | 'ELIMINATION'
  kind        String

  // Input parameters as JSON — shape depends on `kind`. For
  // CONSOLIDATION: { scenarioId, entityId, yearCode }. Keep it flexible
  // so each process type can carry its own params.
  params      Json     @default("{}")

  // Lifecycle. Sync runs go QUEUED → RUNNING → SUCCEEDED/FAILED in one
  // request. Async (future) sits in QUEUED then a worker picks it up.
  status      String   @default("QUEUED")           // QUEUED | RUNNING | SUCCEEDED | FAILED
  startedAt   DateTime?
  finishedAt  DateTime?

  // Result counts so the history table can show "Read 1,200 / wrote 80"
  // without needing to re-query the underlying tables.
  rowsRead    Int?
  rowsWritten Int?
  rowsErrored Int?

  // Free-text error trail for failed runs (top of stack, truncated).
  error       String?

  // Optional human-readable summary the engine writes on success — e.g.
  // "Consolidated 3 entities across 12 months, eliminated 4 IC pairs".
  summary     String?

  // Versioned snapshot of the metadata at run time (for replay/diff).
  metadataSnapshot Json?

  startedBy   String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, kind, startedAt(sort: Desc)])
  @@index([tenantId, status])
  @@map("process_runs")
}

// ═══════════════════════════════════════════════════════════════════
// Load batches — every file import gets a batch row. FactRow.loadBatchId
// FKs here so we can audit "which row came from which file" and support
// roll-back-by-batch in Phase 2.
// ═══════════════════════════════════════════════════════════════════

model LoadBatch {
  id            String   @id @default(uuid())
  tenantId      String
  processRunId  String?                              // links to the ProcessRun for unified history
  filename      String
  fileSize      Int
  mimeType      String?
  rowsTotal     Int
  rowsCommitted Int
  uploadedBy    String
  uploadedAt    DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, uploadedAt(sort: Desc)])
  @@map("load_batches")
}

// ═══════════════════════════════════════════════════════════════════
// AI Cache + AI Call Logs — cost-discipline backbone.
// Cache: hash(model + skill + payload) → response. Identical re-asks
//        within TTL serve free.
// Logs:  every AI call recorded for per-tenant cost tracking + daily cap.
// ═══════════════════════════════════════════════════════════════════

model AiCache {
  id          String   @id @default(uuid())
  tenantId    String
  cacheKey    String                                // sha256(model + prompt + payload)
  kind        String                                // 'variance' | 'narrative' | 'classify' | etc
  model       String                                // 'haiku-4.5' | 'sonnet-4.6' | 'gemini-2.5-flash'
  response    String                                // markdown or json
  promptTokens Int
  outputTokens Int
  costInr      Decimal @db.Decimal(12, 4)           // estimated cost in INR
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  hitCount    Int      @default(0)                  // bumped each time served from cache
  lastHitAt   DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, cacheKey])
  @@index([tenantId, expiresAt])
  @@index([tenantId, kind])
  @@map("ai_cache")
}

model AiCallLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  kind        String                                // surface name e.g. 'variance-explainer'
  model       String
  promptTokens Int
  outputTokens Int
  costInr     Decimal  @db.Decimal(12, 4)
  cached      Boolean  @default(false)              // true when served from AiCache
  latencyMs   Int
  acceptedByUser Boolean?                            // null until user reacts
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, kind])
  @@map("ai_call_logs")
}

// ═══════════════════════════════════════════════════════════════════
// Monthly Close — checklist + status tracking
// Templates seed the 5-day playbook from finance:close-management.
// CloseRun = per-period instance. CloseTask = individual checkbox.
// ═══════════════════════════════════════════════════════════════════

model CloseRun {
  id           String   @id @default(uuid())
  tenantId     String
  periodCode   String                                // e.g. "2026M04"
  status       String   @default("OPEN")             // OPEN | LOCKED | REOPENED
  startedAt    DateTime @default(now())
  closedAt     DateTime?
  createdBy    String
  closedBy     String?
  notes        String?

  tasks        CloseTask[]
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, periodCode])
  @@index([tenantId, status])
  @@map("close_runs")
}

model CloseTask {
  id           String   @id @default(uuid())
  tenantId     String
  closeRunId   String

  dayOffset    Int                                   // -2..5 (T-2 pre-close → T+5 final)
  category     String                                // RECONCILIATION | JOURNAL_ENTRIES | REVIEW | LOCK
  title        String
  description  String?

  status       String   @default("PENDING")          // PENDING | IN_PROGRESS | DONE | BLOCKED | SKIPPED
  owner        String?                               // user id
  dueDate      DateTime?
  completedAt  DateTime?
  completedBy  String?
  notes        String?

  // Auto-detect completion: if any fact for this period has this origin, mark DONE
  autoStatusOrigin String?                           // e.g. "Import"

  sortOrder    Int      @default(0)
  closeRun     CloseRun @relation(fields: [closeRunId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([closeRunId, dayOffset])
  @@index([tenantId, status])
  @@map("close_tasks")
}

// ═══════════════════════════════════════════════════════════════════
// CalcRule — saved declarative calc specifications.
// Created either manually or via "vibe coding" (user describes in NL,
// AI generates the spec, user reviews + saves). At run-time the engine
// reads the spec and executes deterministic math — no LLM in the loop.
// ═══════════════════════════════════════════════════════════════════

model CalcRule {
  id           String   @id @default(uuid())
  tenantId     String
  code         String                                // url-friendly, unique per tenant
  name         String
  description  String?

  // Rule spec — JSON shape:
  //   {
  //     filters: { scenario?, entityIds?, accountIds?, periodCodes?, accountTypePrefix? },
  //     formula: { kind: 'percentage'|'allocation'|'sumProduct'|'rate'|'custom', ... },
  //     output:  { accountId, scenarioId?, origin: 'AI'|'Calc', overwriteExisting: bool }
  //   }
  spec         Json     @default("{}")

  // What kind of rule:
  //   ALLOCATION    — spread one account to many by driver
  //   PERCENTAGE    — apply % to filtered facts
  //   SUM           — aggregate filtered facts to a target
  //   FX_CONVERT    — apply FX
  //   COMP_BUILD    — total comp from base × multipliers
  //   CUSTOM        — sandboxed JS expression
  kind         String   @default("PERCENTAGE")

  // Status: DRAFT (vibe-created, not yet reviewed), ACTIVE, DISABLED, ARCHIVED
  status       String   @default("DRAFT")

  // Source: 'manual', 'vibe' (NL-generated), 'template'
  source       String   @default("manual")

  // Track AI generation for audit
  vibePrompt   String?                               // original user NL prompt
  vibeModel    String?                               // which AI model generated it

  createdBy    String
  createdAt    DateTime @default(now())
  updatedBy    String?
  updatedAt    DateTime @updatedAt
  lastRunAt    DateTime?
  lastRunBy    String?
  runCount     Int      @default(0)

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runs         CalcRuleRun[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("calc_rules")
}

model CalcRuleRun {
  id           String   @id @default(uuid())
  tenantId     String
  ruleId       String
  status       String   @default("RUNNING")          // RUNNING | SUCCEEDED | FAILED
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  rowsRead     Int?
  rowsWritten  Int?
  errorMessage String?
  triggeredBy  String                                // user id, or 'automation:<jobId>'

  rule         CalcRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, ruleId, startedAt(sort: Desc)])
  @@map("calc_rule_runs")
}

// ═══════════════════════════════════════════════════════════════════
// Automation — repeatable jobs (backups, exports, calc runs, reports)
// Designed simpler than EPM:
//   - 5 job kinds (not 50)
//   - Cron-style schedule OR manual trigger
//   - Each run logged to JobRun with output URL or summary
// ═══════════════════════════════════════════════════════════════════

model AutomationJob {
  id           String   @id @default(uuid())
  tenantId     String
  code         String                                // url-friendly
  name         String
  description  String?

  // What kind of job:
  //   EXPORT_FACTS         — dump fact_rows to S3/file for backup
  //   EXPORT_METADATA      — dump all dimensions to xlsx
  //   RUN_CONSOLIDATION    — trigger /api/v2/processes/consolidation
  //   RUN_CALC_RULE        — trigger a saved CalcRule
  //   SEND_REPORT          — generate report (PDF/email)
  //   RUN_PIPELINE         — orchestrator chain (Phase 2)
  kind         String

  // Job params — kind-specific JSON
  params       Json     @default("{}")

  // Schedule (cron or 'manual'). Examples: "0 6 * * *" daily 6am, "manual"
  schedule     String   @default("manual")
  timezone     String   @default("UTC")

  enabled      Boolean  @default(true)
  createdBy    String
  createdAt    DateTime @default(now())
  updatedBy    String?
  updatedAt    DateTime @updatedAt

  lastRunAt    DateTime?
  lastRunStatus String?
  nextRunAt    DateTime?
  runCount     Int      @default(0)

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runs         JobRun[]

  @@unique([tenantId, code])
  @@index([tenantId, enabled])
  @@map("automation_jobs")
}

model JobRun {
  id           String   @id @default(uuid())
  tenantId     String
  jobId        String
  status       String   @default("RUNNING")          // RUNNING | SUCCEEDED | FAILED
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  triggeredBy  String                                // 'cron' | 'manual:<userId>'
  output       Json?                                 // summary, file url, row counts, etc
  errorMessage String?

  job          AutomationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, jobId, startedAt(sort: Desc)])
  @@map("job_runs")
}

// ═══════════════════════════════════════════════════════════════════
// Copilot conversations — chat history per user.
// Each message can have associated tool_use blocks for full audit.
// ═══════════════════════════════════════════════════════════════════

model CopilotConversation {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  title        String   @default("New chat")        // first user message snippet
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages     CopilotMessage[]
  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, updatedAt(sort: Desc)])
  @@map("copilot_conversations")
}

model CopilotMessage {
  id              String   @id @default(uuid())
  conversationId  String
  role            String                              // 'user' | 'assistant' | 'tool'
  content         String                              // plain text
  toolUseBlocks   Json?                               // array of {tool_name, input, result}
  model           String?
  promptTokens    Int?
  outputTokens    Int?
  costInr         Decimal? @db.Decimal(12, 4)
  createdAt       DateTime @default(now())

  conversation    CopilotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("copilot_messages")
}

// ═══════════════════════════════════════════════════════════════════
// Snapshots — point-in-time backup of fact_rows (and metadata).
// Pattern: store the captured rows as a JSONB payload on the Snapshot
// record itself, rather than copying into fact_rows with a synthetic
// originId. This avoids surgery on the long fact unique constraint and
// keeps snapshots fully independent of live data.
//
// Scope is captured in `scope` (Json): { scenarioCode?, entityCodes?,
// periodCodes?, accountCodes? }. Empty scope = full tenant snapshot.
// Restore re-materialises fact_rows from payload, marking matching live
// rows as superseded (isCurrent=false) — implemented in a later ship.
// ═══════════════════════════════════════════════════════════════════

model Snapshot {
  id           String   @id @default(uuid())
  tenantId     String

  label        String                                // human-readable, e.g. "Q1 2026 close"
  description  String?

  // Scope filters that defined what was captured
  scope        Json     @default("{}")               // { scenarioCode?, entityCodes?, periodCodes?, accountCodes? }
  scenarioCode String?                                // denormalised single-scenario hint for UI sorting
  periodHint   String?                                // e.g. "FY2026" / "2026Q1" — for sorting in UI

  // Snapshot payload — array of fact-row projections
  // Each item: { scenarioId, timeId, entityId, accountId, icpId, originId,
  //              ud1Id..ud8Id, valueTxn, valueLocal, valueReporting,
  //              currencyId, scenarioCode, periodCode, entityCode, accountCode }
  payload      Json     @default("[]")
  factCount    Int      @default(0)
  payloadBytes Int      @default(0)                  // approx size for display
  status       String   @default("READY")            // READY | RESTORED | DELETED

  createdById  String                                 // user.id of creator
  createdAt    DateTime @default(now())
  restoredAt   DateTime?
  restoredById String?

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, status])
  @@map("snapshots")
}

